# Zeno Configuration Example
#
# Copy this to .env and fill in your credentials, then Zeno will auto-load them
# for real LLM provider access. Leave commented/empty for offline (mock) mode.

# ============================================================================
# Model Selection
# ============================================================================
# Default model. Options: "mock" (offline, default), or any litellm model string
ZENO_MODEL=mock

# Path to Python executable (if not in PATH)
# ZENO_PYTHON=python3.13

# ============================================================================
# Anthropic (Claude)
# ============================================================================
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL_ID=claude-3-5-sonnet-20241022

# ============================================================================
# Azure OpenAI (GPT-4, GPT-3.5)
# ============================================================================
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ============================================================================
# OpenAI (GPT-4, GPT-3.5, etc.)
# ============================================================================
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ============================================================================
# Local Models (Ollama, LM Studio, etc.)
# ============================================================================
# For local models, litellm will route to them automatically
# Examples:
#   ZENO_MODEL=ollama/llama2
#   ZENO_MODEL=ollama/neural-chat
#   ZENO_MODEL=local/your-local-model

# ============================================================================
# Debugging
# ============================================================================
# Uncomment for verbose litellm logs
# LITELLM_LOG=DEBUG
