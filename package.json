{
  "name": "zeno",
  "version": "0.0.1",
  "private": true,
  "description": "Zeno — ultra-lean AI coding harness",
  "type": "module",
  "workspaces": [
    "packages/zeno-coding-agent",
    "packages/zeno-tui"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start": "node scripts/start.js",
    "test:node": "npm run test --workspaces --if-present",
    "test:py": "python -m pytest packages -q"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
